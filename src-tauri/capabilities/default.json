{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "core:path:default",
    "core:fs:allow-write-file",
    "core:fs:allow-read-file"
  ]
}
